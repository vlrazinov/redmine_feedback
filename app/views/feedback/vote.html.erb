<h2><%= l(:label_feedback_title) %></h2>

<% if @existing_feedback.present? %>
  <div class="flash notice">
    <%
      rating_text = case @existing_feedback
                    when 'good', 'Хорошо' then l(:label_good)
                    when 'okay', 'Нормально' then l(:label_okay)
                    when 'bad', 'Плохо' then l(:label_bad)
                    else @existing_feedback
                    end
    %>
    <%= l(:notice_already_voted, rating: rating_text) %>
    <% if @existing_comment.present? %>
      <p><strong><%= l(:field_comment) %>:</strong> <%= @existing_comment %></p>
    <% end %>
  </div>
  <p>
    <%= link_to l(:button_change), '#', onclick: "document.getElementById('feedback-form').style.display='block'; this.style.display='none'; return false;", class: 'icon icon-edit' %>
  </p>
  <%= form_tag feedback_submit_path(@issue.id, token: params[:token]), method: :post, class: 'feedback-form', id: 'feedback-form', style: 'display:none;' do %>
    <div class="box">
      <p>
        <label><%= l(:label_feedback_rating) %></label>
        <span class="rating-options">
          <%
            current_rating = case @existing_feedback
                            when 'good', 'Хорошо' then 'good'
                            when 'okay', 'Нормально' then 'okay'
                            when 'bad', 'Плохо' then 'bad'
                            else 'okay'
                            end
          %>
          <label><%= radio_button_tag 'rating', 'good', current_rating == 'good' %> <%= l(:label_good) %></label>
          <label><%= radio_button_tag 'rating', 'okay', current_rating == 'okay' %> <%= l(:label_okay) %></label>
          <label><%= radio_button_tag 'rating', 'bad', current_rating == 'bad' %> <%= l(:label_bad) %></label>
        </span>
      </p>
      <p>
        <%= label_tag :comment, l(:field_comment) %>
        <%= text_area_tag :comment, @existing_comment || '', rows: 5, style: 'width: 100%; max-width: 600px;' %>
      </p>
    </div>
    <p><%= submit_tag l(:button_submit), class: 'button-positive' %></p>
  <% end %>
<% else %>
  <%= form_tag feedback_submit_path(@issue.id, token: params[:token]), method: :post, class: 'feedback-form', id: 'feedback-form' do %>
    <div class="box">
      <p>
        <label><%= l(:label_feedback_rating) %></label>
        <span class="rating-options">
          <label><%= radio_button_tag 'rating', 'good' %> <%= l(:label_good) %></label>
          <label><%= radio_button_tag 'rating', 'okay' %> <%= l(:label_okay) %></label>
          <label><%= radio_button_tag 'rating', 'bad' %> <%= l(:label_bad) %></label>
        </span>
      </p>
      <p>
        <%= label_tag :comment, l(:field_comment) %>
        <%= text_area_tag :comment, '', rows: 5, style: 'width: 100%; max-width: 600px;' %>
      </p>
    </div>
    <p><%= submit_tag l(:button_submit), class: 'button-positive' %></p>
  <% end %>
<% end %>
